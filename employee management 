employees = ["Amit", "Jyoti", "Rahul", "Amit", "Priya"]

unique_employees = list(set(employees))
salaries = {
    "Amit": 60000,
    "Jyoti": 45000,
    "Rahul": 70000,
    "Priya": 32000
}

employee_details = (101, "IT Department")
print("--- Employee List ---")
for emp in unique_employees:
    print("Name:", emp)
print()

highest_salary = 0
highest_paid_emp = ""

for emp in salaries:
    current_salary = salaries[emp]
    if current_salary > highest_salary:
        highest_salary = current_salary
        highest_paid_emp = emp

print("Highest Paid Employee:", highest_paid_emp, "with salary:", highest_salary)
print()



print("--- Employee Categories ---")
for emp in salaries:
    salary = salaries[emp]
    if salary >= 50000:
        print(emp, "is a Senior Employee")
    else:
        print(emp, "is a Junior Employee")
print()

search_name = "rahul"  

print("--- Search Result ---")
found = False
for emp in salaries:
 
    if emp.lower() == search_name.lower():
        print("Employee Found! Name:", emp, "| Salary:", salaries[emp])
        print("ID and Dept details:", employee_details)
        found = True
        break

if found == False:
    print("Employee not found in our records.")
print()

print("--- Updating Salary ---")

salaries["Amit"] = 65000
print("Updated salary of Amit is:", salaries["Amit"])